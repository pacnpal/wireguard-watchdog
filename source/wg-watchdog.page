<?
$plugin = "wg-watchdog";
$cfg    = parse_plugin_cfg($plugin);

$defaults = [
    'SERVICE_ENABLED' => 'no',
    'INTERFACE'       => 'wg0',
    'PEER_IP'         => '10.99.0.1',
    'INTERVAL'        => '60',
    'VERBOSE'         => 'no',
    'LOG_FILE'        => '/var/log/wg-watchdog.log',
];
foreach ($defaults as $k => $v) {
    if (!isset($cfg[$k]) || $cfg[$k] === '') $cfg[$k] = $v;
}
?>

<div style="width: 75%; float:left">

<form markdown="1" name="wg_watchdog" method="POST" action="/update.php" target="progressFrame">
<input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
<input type="hidden" name="#file"      value="wg-watchdog/wg-watchdog.cfg">
<input type="hidden" name="#command"   value="plugins/wg-watchdog/scripts/install_cron.sh">

:wg_watchdog_intro_plug:
> WireGuard Watchdog pings a peer through your WireGuard tunnel on a
> schedule. If the peer becomes unreachable, the tunnel is bounced via
> `wg-quick down` / `wg-quick up`. Requires Unraid's built-in WireGuard
> support (Settings → VPN Manager) and at least one configured tunnel.
:end

_(Enabled)_:
: <select name="SERVICE_ENABLED" size="1">
    <?=mk_option($cfg['SERVICE_ENABLED'], "no",  "_(No)_")?>
    <?=mk_option($cfg['SERVICE_ENABLED'], "yes", "_(Yes)_")?>
  </select>

:wg_watchdog_enabled_plug:
> Master toggle. When set to 'No' the watchdog cron entry is removed
> and no checks are run.
:end

_(Tunnel interface)_:
: <input type="text" name="INTERFACE" class="narrow" maxlength="15" value="<?=htmlspecialchars($cfg['INTERFACE'])?>" placeholder="wg0">

:wg_watchdog_interface_plug:
> The WireGuard interface to monitor (e.g. `wg0`, `wg1`). Managed by
> Unraid's built-in VPN Manager -- this watchdog only invokes
> `wg-quick down` / `wg-quick up`.
:end

_(Peer IP to ping)_:
: <input type="text" name="PEER_IP" class="narrow" maxlength="45" value="<?=htmlspecialchars($cfg['PEER_IP'])?>" placeholder="10.99.0.1">

:wg_watchdog_peer_plug:
> An IP reachable through the tunnel -- typically the remote peer's
> internal address.
:end

_(Check interval)_ _(seconds)_:
: <input type="number" name="INTERVAL" class="narrow" min="20" step="1" value="<?=htmlspecialchars($cfg['INTERVAL'])?>" placeholder="60">

:wg_watchdog_interval_plug:
> How often to ping (minimum 20 seconds). Below 60s the cron file is
> generated as multiple per-minute lines with `sleep` offsets.
:end

_(Verbose logging)_:
: <select name="VERBOSE" size="1">
    <?=mk_option($cfg['VERBOSE'], "no",  "_(No)_")?>
    <?=mk_option($cfg['VERBOSE'], "yes", "_(Yes)_")?>
  </select>

:wg_watchdog_verbose_plug:
> If 'Yes', every check is logged with full ping stats. Otherwise only
> failures and recovery actions are logged. Use sparingly to avoid
> growing the log file.
:end

_(Log file)_:
: <input type="text" name="LOG_FILE" class="narrow" value="<?=htmlspecialchars($cfg['LOG_FILE'])?>" readonly>

:wg_watchdog_logfile_plug:
> Read-only. Defaults to `/var/log/wg-watchdog.log` and is recreated on
> each boot (logs are not persisted across reboots).
:end

<input type="submit" name="#default" value="_(Default)_">
: <input type="submit" name="#apply" value="_(Apply)_"><input type="button" value="_(Done)_" onclick="done()">

</form>

</div>

<div style="width: 75%; float:left; margin-top: 20px;">
<form markdown="1" name="wg_watchdog_actions">

_(Diagnostics)_:
: <input type="button" value="_(Test Now)_" onclick="wgTest()">
  <input type="button" value="_(View Log)_" onclick="wgLog()">
  <input type="button" value="_(Clear Log)_" onclick="wgClear()">

</form>
<div id="wg-watchdog-output"
     style="display:none;white-space:pre-wrap;font-family:monospace;background:#111;color:#eee;padding:10px;margin-top:10px;max-height:420px;overflow:auto;border-radius:4px;"></div>
</div>

<script>
function wgWatchdogShow(text) {
    var out = document.getElementById('wg-watchdog-output');
    out.style.display = 'block';
    out.textContent = text;
}
function wgTest() {
    wgWatchdogShow('Running test...');
    $.post('/plugins/wg-watchdog/include/test.php', {csrf_token: csrf_token},
           function(data) { wgWatchdogShow(data || '(no output)'); })
     .fail(function(xhr) { wgWatchdogShow('Error: ' + xhr.status + ' ' + xhr.statusText); });
}
function wgLog() {
    wgWatchdogShow('Loading log...');
    $.get('/plugins/wg-watchdog/include/log.php', {csrf_token: csrf_token},
          function(data) { wgWatchdogShow(data || '(log empty)'); })
     .fail(function(xhr) { wgWatchdogShow('Error: ' + xhr.status + ' ' + xhr.statusText); });
}
function wgClear() {
    if (!confirm("_(Clear the WireGuard Watchdog log?)_")) return;
    wgWatchdogShow('Clearing log...');
    $.post('/plugins/wg-watchdog/include/clear.php', {csrf_token: csrf_token},
           function(data) { wgWatchdogShow(data || 'Log cleared.'); })
     .fail(function(xhr) { wgWatchdogShow('Error: ' + xhr.status + ' ' + xhr.statusText); });
}
</script>
